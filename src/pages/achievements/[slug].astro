---
import Layout from '../../layouts/Layout.astro'
import Navbar from '../../components/Navbar.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const achievements = await getCollection('achievements')

  return achievements.map((achievement) => ({
    params: {
      slug: achievement.data.slug,
    },
    props: {
      achievement,
    },
  }))
}

const { achievement } = Astro.props
const { Content } = await render(achievement)

const hasEvidence = achievement.data.evidence.length > 0
const hasRelatedLink = achievement.data.link.length > 0
---

<Layout title={`${achievement.data.title} — Achievements`}>
  <main class="min-h-screen bg-[#090909] text-[#f3efe4]">
    <Navbar current="Achievements" />

    <!-- HERO -->
    <section class="site-grid px-6 pt-36 pb-20">
      <div class="mx-auto max-w-7xl">
        <a
          href="/achievements"
          class="font-mono text-xs uppercase tracking-widest text-[#a9a196] transition hover:text-[#c9ff5f]"
        >
          ← Back to achievements
        </a>

        <div class="mt-10 flex flex-wrap gap-3">
          <span class="rounded-full border border-white/10 px-4 py-2 font-mono text-xs uppercase tracking-widest text-[#c9ff5f]">
            {achievement.data.type}
          </span>

          <span class="rounded-full border border-white/10 px-4 py-2 font-mono text-xs uppercase tracking-widest text-[#a9a196]">
            {achievement.data.status}
          </span>

          <span class="rounded-full border border-white/10 px-4 py-2 font-mono text-xs uppercase tracking-widest text-[#a9a196]">
            {achievement.data.date}
          </span>
        </div>

        <h1 class="display-text neon-cream mt-8 max-w-6xl text-6xl uppercase leading-none tracking-[-0.06em] md:text-8xl">
          {achievement.data.title}
        </h1>

        <p class="mt-8 max-w-4xl text-base leading-8 text-[#a9a196]">
          {achievement.data.description}
        </p>

        {achievement.data.cover && (
          <img
            src={achievement.data.cover}
            alt={achievement.data.title}
            class="mt-10 max-h-[620px] w-full rounded-3xl border border-white/10 object-cover"
          />
        )}
      </div>
    </section>

    <!-- CONTENT -->
    <section class="mx-auto grid max-w-7xl gap-8 px-6 pb-28 lg:grid-cols-[1fr_0.65fr]">
      <article class="neon-card rounded-3xl border border-white/10 bg-[#111111] p-8">
        <p class="neon-lime font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
          Details
        </p>

        <div class="mt-8 space-y-6 text-base leading-8 text-[#a9a196] [&_h2]:mt-10 [&_h2]:font-mono [&_h2]:text-xs [&_h2]:uppercase [&_h2]:tracking-[0.3em] [&_h2]:text-[#c9ff5f] [&_ul]:ml-5 [&_ul]:list-disc [&_ol]:ml-5 [&_ol]:list-decimal [&_li]:mt-2">
          <Content />
        </div>
      </article>

      <aside class="space-y-8">
        <article class="neon-card rounded-3xl border border-white/10 bg-[#111111] p-8">
          <p class="neon-lime font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
            Metadata
          </p>

          <div class="mt-6 grid gap-3">
            <div class="rounded-2xl border border-white/10 bg-black/30 p-4">
              <p class="font-mono text-[0.65rem] uppercase tracking-widest text-[#a9a196]">
                Type
              </p>
              <p class="mt-2 text-sm font-bold text-[#f3efe4]">
                {achievement.data.type}
              </p>
            </div>

            <div class="rounded-2xl border border-white/10 bg-black/30 p-4">
              <p class="font-mono text-[0.65rem] uppercase tracking-widest text-[#a9a196]">
                Status
              </p>
              <p class="mt-2 text-sm font-bold text-[#f3efe4]">
                {achievement.data.status}
              </p>
            </div>

            <div class="rounded-2xl border border-white/10 bg-black/30 p-4">
              <p class="font-mono text-[0.65rem] uppercase tracking-widest text-[#a9a196]">
                Date
              </p>
              <p class="mt-2 text-sm font-bold text-[#f3efe4]">
                {achievement.data.date}
              </p>
            </div>
          </div>
        </article>

        {hasEvidence && (
          <article class="neon-card rounded-3xl border border-white/10 bg-[#111111] p-8">
            <p class="neon-lime font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
              Evidence
            </p>

            <div class="mt-6 grid gap-3">
              {achievement.data.evidence.map((item, index) => (
                <div class="flex items-center justify-between gap-4 rounded-2xl border border-white/10 bg-black/30 p-4">
                  <span class="font-mono text-xs text-[#c9ff5f]">
                    0{index + 1}
                  </span>

                  <span class="text-right text-sm font-bold text-[#f3efe4]">
                    {item}
                  </span>
                </div>
              ))}
            </div>
          </article>
        )}

        {hasRelatedLink && (
          <a
            href={achievement.data.link}
            class="block rounded-3xl border border-[#c9ff5f]/20 bg-[#c9ff5f] p-8 text-black transition hover:scale-[1.01]"
          >
            <p class="font-mono text-xs font-black uppercase tracking-[0.3em]">
              Related Page
            </p>

            <p class="mt-5 text-sm font-bold">
              Open related archive page →
            </p>
          </a>
        )}

        <article class="rounded-3xl border border-[#c9ff5f]/20 bg-[#c9ff5f] p-8 text-black">
          <p class="font-mono text-xs font-black uppercase tracking-[0.3em]">
            Edit this achievement
          </p>

          <p class="mt-5 text-sm leading-7">
            Update this page from:
          </p>

          <p class="mt-4 break-all rounded-2xl bg-black px-4 py-3 font-mono text-xs text-[#c9ff5f]">
            src/content/achievements/{achievement.id}
          </p>
        </article>
      </aside>
    </section>
  </main>
</Layout>
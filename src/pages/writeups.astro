---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/Navbar.astro'
import { getCollection } from 'astro:content'

const writeups = await getCollection('writeups')
const sortedWriteups = writeups.sort((a, b) => a.data.order - b.data.order)

const totalWriteups = sortedWriteups.length

const platforms = [
  ...new Set(sortedWriteups.map((writeup) => writeup.data.platform || 'General')),
]

const tracks = [
  ...new Set(sortedWriteups.map((writeup) => writeup.data.track || 'Writeups')),
]

const categories = [
  ...new Set(sortedWriteups.map((writeup) => writeup.data.category)),
]

const pinnedWriteups = sortedWriteups.filter((writeup) => writeup.data.pinned)
const featuredWriteups = sortedWriteups.filter((writeup) => writeup.data.featured)

const groupedByPlatform = platforms.map((platform) => {
  const platformWriteups = sortedWriteups.filter(
    (writeup) => (writeup.data.platform || 'General') === platform
  )

  const seriesList = [
    ...new Set(platformWriteups.map((writeup) => writeup.data.series || 'General')),
  ]

  const seriesGroups = seriesList.map((series) => {
    const seriesWriteups = platformWriteups.filter(
      (writeup) => (writeup.data.series || 'General') === series
    )

    return {
      series,
      writeups: seriesWriteups,
    }
  })

  return {
    platform,
    writeups: platformWriteups,
    seriesGroups,
  }
})

const platformAccent = (platform: string) => {
  const lower = platform.toLowerCase()

  if (lower.includes('pico')) {
    return {
      dot: 'bg-[#6aa9ff]',
      text: 'text-[#6aa9ff]',
      border: 'border-[#6aa9ff]/25',
      bg: 'bg-[#6aa9ff]/5',
    }
  }

  if (lower.includes('over') || lower.includes('bandit') || lower.includes('natas')) {
    return {
      dot: 'bg-[#28f6d0]',
      text: 'text-[#28f6d0]',
      border: 'border-[#28f6d0]/25',
      bg: 'bg-[#28f6d0]/5',
    }
  }

  if (lower.includes('sieberr') || lower.includes('ctf')) {
    return {
      dot: 'bg-[#ff5f7e]',
      text: 'text-[#ff5f7e]',
      border: 'border-[#ff5f7e]/25',
      bg: 'bg-[#ff5f7e]/5',
    }
  }

  return {
    dot: 'bg-[#c9ff5f]',
    text: 'text-[#c9ff5f]',
    border: 'border-[#c9ff5f]/25',
    bg: 'bg-[#c9ff5f]/5',
  }
}
---

<Layout title="Writeups — Yaohan">
  <main class="min-h-screen bg-[#090909] text-[#f3efe4]">
    <Navbar current="Writeups" />

    <!-- HERO -->
    <section class="site-grid px-6 pt-36 pb-16">
      <div class="mx-auto max-w-7xl">
        <p class="font-mono text-xs uppercase tracking-[0.35em] text-[#a9a196]">
          Technical Archive / CTF Notes
        </p>

        <h1 class="display-text neon-cream mt-5 text-7xl uppercase leading-none tracking-[-0.06em] md:text-9xl">
          Writeups
        </h1>

        <div class="mt-6 h-px w-20 bg-[#ead27c]"></div>

        <p class="mt-8 max-w-3xl text-base leading-8 text-[#a9a196]">
          CTF challenge notes, payload testing, exploitation steps, solved
          writeups, and technical maps for things I want to understand properly.
        </p>

        <p class="mt-6 font-mono text-sm uppercase tracking-[0.25em] text-[#6f6a63]">
          {totalWriteups} posts across {platforms.length} platforms
        </p>
      </div>
    </section>

    <!-- TRACK CARDS -->
    <section class="mx-auto max-w-7xl px-6 pb-12">
      <div class="grid gap-6 md:grid-cols-2">
        {tracks.map((track) => {
          const count = sortedWriteups.filter(
            (writeup) => (writeup.data.track || 'Writeups') === track
          ).length

          return (
            <article class="rounded-3xl border border-white/10 bg-[#111111]/80 p-7 transition hover:border-[#c9ff5f]/35 hover:bg-[#151515]">
              <div class="flex items-start justify-between gap-6">
                <div>
                  <h2 class="font-mono text-lg font-bold text-[#c9c2b8]">
                    {track}
                  </h2>

                  <p class="mt-5 max-w-xl text-sm leading-7 text-[#6f6a63]">
                    Challenge notes, technical summaries, and walkthroughs grouped
                    by platform, category, series, and level.
                  </p>

                  <a
                    href="#writeup-map"
                    class="mt-6 inline-flex font-mono text-sm lowercase tracking-widest text-[#ead27c] transition hover:text-[#c9ff5f]"
                  >
                    filter →
                  </a>
                </div>

                <p class="font-mono text-sm text-[#6f6a63]">
                  {count} posts
                </p>
              </div>
            </article>
          )
        })}
      </div>
    </section>

    <!-- SEARCH BAR / STATIC FOR NOW -->
    <section class="mx-auto max-w-7xl px-6 pb-10">
      <div class="rounded-2xl border border-white/10 bg-[#111111]/80 px-6 py-5">
        <p class="font-mono text-sm text-[#6f6a63]">
          Search posts or #tags later...
        </p>
      </div>
    </section>

    <!-- PINNED / FEATURED MAPS -->
    <section class="mx-auto max-w-7xl px-6 pb-16">
      <div class="grid gap-5">
        <a
          href="#writeup-map"
          class="group rounded-3xl border border-[#ead27c]/30 bg-[#ead27c]/5 p-7 transition hover:border-[#ead27c]/60"
        >
          <div class="flex items-start justify-between gap-5">
            <div>
              <p class="font-mono text-sm text-[#d2b26d]">Writeups</p>

              <h2 class="serif-text mt-4 text-3xl font-bold text-[#f3efe4]">
                Writeups Map
              </h2>

              <p class="mt-3 text-sm leading-7 text-[#6f6a63]">
                All technical writeups grouped by platform, series, category,
                and level.
              </p>
            </div>

            <div class="rounded-xl border border-[#ead27c]/30 bg-[#ead27c]/10 px-4 py-2 font-mono text-xs lowercase text-[#d2b26d]">
              map
            </div>
          </div>
        </a>

        {pinnedWriteups.map((writeup) => (
          <a
            href={`/writeups/${writeup.data.slug}`}
            class="group rounded-3xl border border-[#c9ff5f]/25 bg-[#c9ff5f]/5 p-7 transition hover:border-[#c9ff5f]/60"
          >
            <div class="flex items-start justify-between gap-5">
              <div>
                <p class="font-mono text-sm text-[#c9ff5f]">
                  {writeup.data.platform || 'Pinned'}
                </p>

                <h2 class="serif-text mt-4 text-3xl font-bold text-[#f3efe4]">
                  {writeup.data.title}
                </h2>

                <p class="mt-3 text-sm leading-7 text-[#6f6a63]">
                  {writeup.data.summary}
                </p>
              </div>

              <div class="rounded-xl border border-[#c9ff5f]/30 bg-[#c9ff5f]/10 px-4 py-2 font-mono text-xs lowercase text-[#c9ff5f]">
                pinned
              </div>
            </div>
          </a>
        ))}

        {featuredWriteups.map((writeup) => (
          <a
            href={`/writeups/${writeup.data.slug}`}
            class="group rounded-3xl border border-[#ff5f7e]/25 bg-[#ff5f7e]/5 p-7 transition hover:border-[#ff5f7e]/60"
          >
            <div class="flex items-start justify-between gap-5">
              <div>
                <p class="font-mono text-sm text-[#ff5f7e]">
                  Featured
                </p>

                <h2 class="serif-text mt-4 text-3xl font-bold text-[#f3efe4]">
                  {writeup.data.title}
                </h2>

                <p class="mt-3 text-sm leading-7 text-[#6f6a63]">
                  {writeup.data.summary}
                </p>
              </div>

              <div class="rounded-xl border border-[#ff5f7e]/30 bg-[#ff5f7e]/10 px-4 py-2 font-mono text-xs lowercase text-[#ff5f7e]">
                featured
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- CATEGORY CHIPS -->
    <section class="border-y border-white/10 bg-[#111111] px-6 py-6">
      <div class="mx-auto flex max-w-7xl flex-wrap gap-3">
        {categories.map((category) => (
          <span class="rounded-full border border-white/10 bg-black/30 px-4 py-2 font-mono text-xs uppercase tracking-widest text-[#a9a196]">
            {category}
          </span>
        ))}
      </div>
    </section>

    <!-- ORGANIZED MAP -->
    <section id="writeup-map" class="mx-auto max-w-7xl px-6 py-28">
      <div class="space-y-24">
        {groupedByPlatform.map((group) => {
          const accent = platformAccent(group.platform)

          return (
            <section>
              <div class="flex flex-wrap items-end justify-between gap-5 border-b border-white/10 pb-6">
                <div>
                  <div class="flex items-center gap-3">
                    <span class={`h-2.5 w-2.5 rounded-full ${accent.dot}`}></span>

                    <h2 class={`serif-text text-3xl font-bold ${accent.text}`}>
                      {group.platform}
                    </h2>

                    <span class="font-mono text-xs text-[#6f6a63]">
                      {group.writeups.length} writeups
                    </span>
                  </div>

                  <p class="mt-4 font-mono text-xs text-[#6f6a63]">
                    {group.platform} challenge notes and technical references
                  </p>
                </div>
              </div>

              <div class="mt-8 space-y-8">
                {group.seriesGroups.map((seriesGroup) => {
                  const hasLevels = seriesGroup.writeups.some(
                    (writeup) => typeof writeup.data.level === 'number'
                  )

                  return (
                    <article class={`rounded-3xl border ${accent.border} ${accent.bg} p-6 md:p-8`}>
                      <div class="flex flex-wrap items-start justify-between gap-5">
                        <div>
                          <p class={`font-mono text-sm font-bold ${accent.text}`}>
                            {seriesGroup.series}
                          </p>

                          <p class="mt-2 text-sm text-[#6f6a63]">
                            {seriesGroup.writeups.length} writeups
                          </p>
                        </div>

                        {hasLevels && (
                          <span class={`rounded-xl border ${accent.border} px-4 py-2 font-mono text-xs lowercase ${accent.text}`}>
                            levels
                          </span>
                        )}
                      </div>

                      {hasLevels ? (
                        <div class="mt-7 grid grid-cols-3 gap-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-10">
                          {seriesGroup.writeups.map((writeup) => (
                            <a
                              href={`/writeups/${writeup.data.slug}`}
                              class="rounded-xl border border-white/10 bg-black/25 px-3 py-4 text-center transition hover:border-[#c9ff5f]/60 hover:bg-black/40"
                            >
                              <p class={`font-mono text-lg font-black ${accent.text}`}>
                                {typeof writeup.data.level === 'number'
                                  ? String(writeup.data.level).padStart(2, '0')
                                  : '—'}
                              </p>

                              <p class="mt-2 truncate font-mono text-[0.62rem] uppercase tracking-widest text-[#6f6a63]">
                                {writeup.data.category}
                              </p>
                            </a>
                          ))}
                        </div>
                      ) : (
                        <div class="mt-7 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                          {seriesGroup.writeups.map((writeup) => (
                            <a
                              href={`/writeups/${writeup.data.slug}`}
                              class="group rounded-2xl border border-white/10 bg-black/25 p-5 transition hover:border-[#c9ff5f]/60 hover:bg-black/40"
                            >
                              <div class="flex items-start justify-between gap-4">
                                <div>
                                  <p class={`font-mono text-xs uppercase tracking-widest ${accent.text}`}>
                                    {writeup.data.category}
                                  </p>

                                  <h3 class="mt-4 text-base font-bold leading-7 text-[#f3efe4]">
                                    {writeup.data.title}
                                  </h3>

                                  <p class="mt-3 line-clamp-2 text-sm leading-6 text-[#6f6a63]">
                                    {writeup.data.summary}
                                  </p>
                                </div>

                                <span class="text-[#6f6a63] transition group-hover:translate-x-1 group-hover:text-[#c9ff5f]">
                                  →
                                </span>
                              </div>
                            </a>
                          ))}
                        </div>
                      )}
                    </article>
                  )
                })}
              </div>
            </section>
          )
        })}
      </div>
    </section>
  </main>
</Layout>
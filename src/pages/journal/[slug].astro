---
import Layout from '../../layouts/Layout.astro'
import Navbar from '../../components/Navbar.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const entries = await getCollection('journal')

  return entries.map((entry) => ({
    params: {
      slug: entry.data.slug,
    },
    props: {
      entry,
    },
  }))
}

const { entry } = Astro.props
const { Content } = await render(entry)
---

<Layout title={`${entry.data.title} — Journal`}>
  <main class="min-h-screen bg-[#090909] text-[#f3efe4]">
    <Navbar current="Journal" />

    <!-- HERO -->
    <section class="site-grid px-6 pt-36 pb-20">
      <div class="mx-auto max-w-7xl">
        <a
          href="/journal"
          class="font-mono text-xs uppercase tracking-widest text-[#a9a196] transition hover:text-[#c9ff5f]"
        >
          ← Back to journal
        </a>

        <div class="mt-10 flex flex-wrap gap-3">
          <span class="rounded-full border border-white/10 px-4 py-2 font-mono text-xs uppercase tracking-widest text-[#c9ff5f]">
            {entry.data.category}
          </span>

          <span class="rounded-full border border-white/10 px-4 py-2 font-mono text-xs uppercase tracking-widest text-[#a9a196]">
            {entry.data.mood}
          </span>

          <span class="rounded-full border border-white/10 px-4 py-2 font-mono text-xs uppercase tracking-widest text-[#a9a196]">
            {entry.data.date}
          </span>
        </div>

        <h1 class="display-text neon-cream mt-8 max-w-6xl text-6xl uppercase leading-none tracking-[-0.06em] md:text-8xl">
          {entry.data.title}
        </h1>

        <p class="mt-8 max-w-3xl text-base leading-8 text-[#a9a196]">
          {entry.data.summary}
        </p>
      </div>
    </section>

    <!-- CONTENT -->
    <section class="mx-auto grid max-w-7xl gap-8 px-6 pb-28 lg:grid-cols-[1fr_0.55fr]">
      <article class="neon-card rounded-3xl border border-white/10 bg-[#111111] p-8">
        <p class="neon-lime font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
          Entry
        </p>

        <div class="mt-8 space-y-6 text-base leading-8 text-[#a9a196] [&_p]:max-w-3xl [&_h2]:mt-10 [&_h2]:font-mono [&_h2]:text-xs [&_h2]:uppercase [&_h2]:tracking-[0.3em] [&_h2]:text-[#c9ff5f] [&_ul]:ml-5 [&_ul]:list-disc [&_li]:mt-2">
          <Content />
        </div>
      </article>

      <aside class="space-y-8">
        <article class="neon-card rounded-3xl border border-white/10 bg-[#111111] p-8">
          <p class="neon-lime font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
            Tags
          </p>

          <div class="mt-6 flex flex-wrap gap-2">
            {entry.data.tags.map((tag) => (
              <span class="rounded-full border border-white/10 bg-black/30 px-3 py-2 font-mono text-xs uppercase tracking-widest text-[#c9c2b8]">
                {tag}
              </span>
            ))}
          </div>
        </article>

        <article class="neon-card rounded-3xl border border-white/10 bg-[#111111] p-8">
          <p class="neon-lime font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
            Takeaway
          </p>

          <p class="mt-6 text-sm leading-7 text-[#a9a196]">
            {entry.data.lesson}
          </p>
        </article>

        <article class="rounded-3xl border border-[#c9ff5f]/20 bg-[#c9ff5f] p-8 text-black">
          <p class="font-mono text-xs font-black uppercase tracking-[0.3em]">
            Edit this entry
          </p>

          <p class="mt-5 text-sm leading-7">
            For now, update this page from:
          </p>

          <p class="mt-4 break-all rounded-2xl bg-black px-4 py-3 font-mono text-xs text-[#c9ff5f]">
            src/content/journal/{entry.id}
          </p>
        </article>
      </aside>
    </section>
  </main>
</Layout>
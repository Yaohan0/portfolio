---
import Layout from '../../layouts/Layout.astro'
import Navbar from '../../components/Navbar.astro'
import { getCollection, render } from 'astro:content'
import { withBase } from '../../utils/paths'

export async function getStaticPaths() {
  const labs = await getCollection('labs')

  return labs.map((lab) => ({
    params: {
      slug: lab.data.slug,
    },
    props: {
      lab,
    },
  }))
}

const { lab } = Astro.props
const { Content } = await render(lab)

const hasCover = Boolean(lab.data.cover)
const hasTools = lab.data.tools.length > 0
const hasTopics = lab.data.topics.length > 0
const hasFiles = lab.data.files.length > 0
---

<Layout title={`${lab.data.title} — Labs`}>
  <main class="min-h-screen bg-[#090909] text-[#f3efe4]">
    <Navbar current="Labs" />

    <!-- HERO -->
    <section class="site-grid px-6 pt-36 pb-16">
      <div class="mx-auto max-w-6xl">
        <a
          href={withBase('labs')}
          class="font-mono text-xs uppercase tracking-widest text-[#6f6a63] transition hover:text-[#c9ff5f]"
        >
          ← Back to Labs
        </a>

        <div class="mt-10 flex flex-wrap gap-2">
          <span class="rounded-full border border-[#c9ff5f]/30 bg-[#c9ff5f]/10 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-widest text-[#c9ff5f]">
            {lab.data.type}
          </span>

          <span class="rounded-full border border-white/10 bg-black/30 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-widest text-[#a9a196]">
            {lab.data.status}
          </span>
        </div>

        <h1 class="display-text neon-cream mt-8 max-w-5xl text-6xl uppercase leading-none tracking-[-0.06em] md:text-8xl">
          {lab.data.title}
        </h1>

        <p class="mt-8 max-w-4xl text-base leading-8 text-[#a9a196]">
          {lab.data.description}
        </p>

        {hasCover && (
          <img
            src={withBase(lab.data.cover)}
            alt={lab.data.title}
            class="mt-10 max-h-[620px] w-full rounded-3xl border border-white/10 object-cover"
          />
        )}
      </div>
    </section>

    <!-- MAIN NOTES -->
    <section class="mx-auto max-w-6xl px-6 pb-16">
      <article class="rounded-3xl border border-white/10 bg-[#0d0d0d]/90 p-8 md:p-12">
        <p class="neon-lime font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
          Lab Notes
        </p>

        <div class="mt-10 space-y-8 text-base leading-9 text-[#a9a196]
          [&_h2]:mt-16 [&_h2]:border-b [&_h2]:border-white/10 [&_h2]:pb-4 [&_h2]:font-serif [&_h2]:text-4xl [&_h2]:font-bold [&_h2]:tracking-[-0.04em] [&_h2]:text-[#f3efe4]
          [&_h3]:mt-12 [&_h3]:font-serif [&_h3]:text-3xl [&_h3]:font-bold [&_h3]:tracking-[-0.03em] [&_h3]:text-[#f3efe4]
          [&_p]:max-w-none [&_p]:leading-9
          [&_ul]:ml-6 [&_ul]:list-disc [&_ol]:ml-6 [&_ol]:list-decimal [&_li]:mt-3
          [&_a]:text-[#c9ff5f] [&_a]:underline
          [&_img]:my-8 [&_img]:w-full [&_img]:rounded-2xl [&_img]:border [&_img]:border-white/10
          [&_code]:rounded-md [&_code]:border [&_code]:border-[#ead27c]/20 [&_code]:bg-[#ead27c]/10 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:font-mono [&_code]:text-sm [&_code]:text-[#ead27c]
          [&_pre]:my-8 [&_pre]:max-h-[720px] [&_pre]:overflow-auto [&_pre]:rounded-2xl [&_pre]:border [&_pre]:border-white/10 [&_pre]:bg-[#20252b] [&_pre]:p-6 [&_pre]:text-sm [&_pre]:leading-7
          [&_pre_code]:border-0 [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:text-[#f3efe4]">
          <Content />
        </div>
      </article>
    </section>

    <!-- EXTRA INFO LOWER DOWN -->
    <section class="mx-auto max-w-6xl px-6 pb-28">
      <div class="grid gap-8 md:grid-cols-2">
        <article class="rounded-3xl border border-white/10 bg-[#111111]/80 p-8">
          <p class="font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
            Tools
          </p>

          {hasTools ? (
            <div class="mt-6 flex flex-wrap gap-2">
              {lab.data.tools.map((tool) => (
                <span class="rounded-full border border-white/10 bg-black/30 px-3 py-2 font-mono text-xs uppercase tracking-widest text-[#c9c2b8]">
                  {tool}
                </span>
              ))}
            </div>
          ) : (
            <p class="mt-6 text-sm leading-7 text-[#6f6a63]">
              No tools listed yet.
            </p>
          )}
        </article>

        <article class="rounded-3xl border border-white/10 bg-[#111111]/80 p-8">
          <p class="font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
            Topics
          </p>

          {hasTopics ? (
            <div class="mt-6 flex flex-wrap gap-2">
              {lab.data.topics.map((topic) => (
                <span class="rounded-full border border-white/10 bg-black/30 px-3 py-2 font-mono text-xs uppercase tracking-widest text-[#c9c2b8]">
                  {topic}
                </span>
              ))}
            </div>
          ) : (
            <p class="mt-6 text-sm leading-7 text-[#6f6a63]">
              No topics listed yet.
            </p>
          )}
        </article>

        <article class="rounded-3xl border border-white/10 bg-[#111111]/80 p-8 md:col-span-2">
          <p class="font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
            Attached Files
          </p>

          {hasFiles ? (
            <div class="mt-6 grid gap-4 md:grid-cols-2">
              {lab.data.files.map((file) => (
                <a
                  href={withBase(file.url)}
                  target="_blank"
                  class="rounded-2xl border border-white/10 bg-black/30 p-5 transition hover:border-[#c9ff5f]/60"
                >
                  <p class="font-mono text-xs uppercase tracking-widest text-[#c9ff5f]">
                    {file.type}
                  </p>

                  <p class="mt-2 text-sm font-bold text-[#f3efe4]">
                    {file.name}
                  </p>
                </a>
              ))}
            </div>
          ) : (
            <p class="mt-6 text-sm leading-7 text-[#6f6a63]">
              No files attached yet.
            </p>
          )}
        </article>
      </div>

      <div class="mt-12 border-t border-white/10 pt-8">
        <a
          href={withBase('labs')}
          class="font-mono text-xs uppercase tracking-widest text-[#6f6a63] transition hover:text-[#c9ff5f]"
        >
          ← Back to Labs
        </a>
      </div>
    </section>
  </main>
</Layout>
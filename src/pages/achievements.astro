---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/Navbar.astro'
import { getCollection } from 'astro:content'

const achievements = await getCollection('achievements')
const sortedAchievements = achievements.sort((a, b) => a.data.order - b.data.order)

const types = [
  ...new Set(sortedAchievements.map((achievement) => achievement.data.type)),
]
---

<Layout title="Achievements — Yaohan">
  <main class="min-h-screen bg-[#090909] text-[#f3efe4]">
    <Navbar current="Achievements" />

    <!-- HERO -->
    <section class="site-grid px-6 pt-36 pb-20">
      <div class="mx-auto max-w-7xl">
        <p class="neon-lime font-mono text-xs uppercase tracking-[0.35em] text-[#c9ff5f]">
          Milestones / Progress Markers
        </p>

        <h1 class="display-text neon-cream mt-5 text-6xl uppercase leading-none tracking-[-0.06em] md:text-9xl">
          Achievements
        </h1>

        <p class="mt-8 max-w-3xl text-base leading-8 text-[#a9a196]">
          Certifications, awards, school milestones, competitions, completed
          work, and proof that I am building skill instead of just collecting
          notes.
        </p>
      </div>
    </section>

    <!-- TYPE STRIP -->
    <section class="border-y border-white/10 bg-[#111111] px-6 py-6">
      <div class="mx-auto flex max-w-7xl flex-wrap gap-3">
        {types.map((type) => (
          <span class="rounded-full border border-white/10 bg-black/30 px-4 py-2 font-mono text-xs uppercase tracking-widest text-[#a9a196]">
            {type}
          </span>
        ))}
      </div>
    </section>

    <!-- ACHIEVEMENTS -->
    <section class="mx-auto max-w-7xl px-6 py-28">
      <div class="relative">
        <div class="absolute left-4 top-0 hidden h-full w-px bg-white/10 md:block"></div>

        <div class="space-y-8">
          {sortedAchievements.map((achievement, index) => (
            <article class="neon-card relative overflow-hidden rounded-3xl border border-white/10 bg-[#111111] md:ml-16">
              <div class="absolute -left-[4.55rem] top-10 hidden h-8 w-8 rounded-full border border-[#c9ff5f]/40 bg-[#090909] shadow-[0_0_24px_rgba(201,255,95,0.25)] md:block">
                <div class="m-2 h-3 w-3 rounded-full bg-[#c9ff5f]"></div>
              </div>

              {achievement.data.cover && (
                <img
                  src={achievement.data.cover}
                  alt={achievement.data.title}
                  class="h-80 w-full border-b border-white/10 object-cover"
                />
              )}

              <div class="p-8">
                <div class="flex flex-wrap items-center justify-between gap-3">
                  <p class="neon-lime font-mono text-xs font-bold uppercase tracking-[0.3em] text-[#c9ff5f]">
                    MILESTONE-0{index + 1}
                  </p>

                  <span class="rounded-full border border-white/10 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-widest text-[#a9a196]">
                    {achievement.data.date}
                  </span>
                </div>

                <h2 class="display-text mt-8 text-5xl uppercase leading-none tracking-[-0.06em] text-[#f3efe4] md:text-6xl">
                  {achievement.data.title}
                </h2>

                <div class="mt-5 flex flex-wrap gap-2">
                  <span class="rounded-full bg-[#c9ff5f] px-3 py-1 font-mono text-[0.65rem] font-black uppercase tracking-widest text-black">
                    {achievement.data.type}
                  </span>

                  <span class="rounded-full border border-white/10 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-widest text-[#a9a196]">
                    {achievement.data.status}
                  </span>
                </div>

                <p class="mt-6 max-w-4xl text-base leading-8 text-[#a9a196]">
                  {achievement.data.description}
                </p>

                {achievement.data.evidence.length > 0 && (
                  <div class="mt-8 flex flex-wrap gap-2">
                    {achievement.data.evidence.map((item) => (
                      <span class="rounded-full border border-white/10 bg-black/30 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-widest text-[#c9c2b8]">
                        {item}
                      </span>
                    ))}
                  </div>
                )}

                <div class="mt-8 flex flex-wrap items-center justify-between gap-4 border-t border-white/10 pt-5">
                  <p class="break-all font-mono text-xs uppercase tracking-widest text-[#a9a196]">
                    src/content/achievements/{achievement.id}
                  </p>

                  <div class="flex flex-wrap gap-3">
                    {achievement.data.link && (
                      <a
                        href={achievement.data.link}
                        class="rounded-full border border-white/15 px-5 py-2 font-mono text-xs uppercase tracking-widest text-[#f3efe4] transition hover:border-[#c9ff5f] hover:text-[#c9ff5f]"
                      >
                        Related page
                      </a>
                    )}

                    <a
                      href={`/achievements/${achievement.data.slug}`}
                      class="rounded-full border border-[#c9ff5f]/40 px-5 py-2 font-mono text-xs uppercase tracking-widest text-[#c9ff5f] transition hover:bg-[#c9ff5f] hover:text-black"
                    >
                      View details
                    </a>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
---
import Layout from '../../layouts/Layout.astro'
import Navbar from '../../components/Navbar.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const writeups = await getCollection('writeups')

  return writeups.map((writeup) => ({
    params: {
      slug: writeup.data.slug,
    },
    props: {
      writeup,
    },
  }))
}

const { writeup } = Astro.props
const { Content } = await render(writeup)

const allWriteups = await getCollection('writeups')

const files = writeup.data.files
const hasFiles = files.length > 0
const hasExternalLink = writeup.data.externalLink.length > 0
const hasLevel = typeof writeup.data.level === 'number'
const hasCover = Boolean(writeup.data.cover)
const hasTags = writeup.data.tags.length > 0

const platform = writeup.data.platform || 'General'
const series = writeup.data.series || 'General'
const track = writeup.data.track || 'Writeups'

const relatedWriteups = allWriteups
  .filter((item) => item.id !== writeup.id)
  .filter((item) => {
    const samePlatform = (item.data.platform || 'General') === platform
    const sameSeries = (item.data.series || 'General') === series
    return samePlatform || sameSeries
  })
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 5)
---

<Layout title={`${writeup.data.title} — Writeups`}>
  <main class="min-h-screen bg-[#090909] text-[#f3efe4]">
    <Navbar current="Writeups" />

    <!-- HERO -->
    <section class="site-grid px-6 pt-36 pb-16">
      <div class="mx-auto max-w-5xl">
        <a
          href="/writeups"
          class="font-mono text-xs uppercase tracking-widest text-[#6f6a63] transition hover:text-[#c9ff5f]"
        >
          ← Back to Writeups
        </a>

        <div class="mt-10 flex flex-wrap gap-2">
          <span class="rounded-full border border-[#ff5f7e]/30 bg-[#ff5f7e]/10 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-widest text-[#ff5f7e]">
            {track}
          </span>

          <span class="rounded-full border border-white/10 bg-black/30 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-widest text-[#a9a196]">
            {platform}
          </span>

          <span class="rounded-full border border-white/10 bg-black/30 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-widest text-[#a9a196]">
            {series}
          </span>

          <span class="rounded-full border border-white/10 bg-black/30 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-widest text-[#a9a196]">
            {writeup.data.category}
          </span>
        </div>

        <h1 class="serif-text mt-8 max-w-5xl text-5xl font-bold leading-tight tracking-[-0.04em] text-[#f3efe4] md:text-7xl">
          {writeup.data.title}
        </h1>

        <p class="mt-6 max-w-3xl text-base leading-8 text-[#a9a196]">
          {writeup.data.summary}
        </p>

        <p class="mt-6 font-mono text-xs uppercase tracking-[0.25em] text-[#6f6a63]">
          {writeup.data.date}
        </p>

        {hasCover && (
          <img
            src={writeup.data.cover}
            alt={writeup.data.title}
            class="mt-10 max-h-[560px] w-full rounded-3xl border border-white/10 object-cover"
          />
        )}
      </div>
    </section>

    <!-- ARTICLE LAYOUT -->
    <section class="mx-auto grid max-w-7xl gap-10 px-6 pb-28 lg:grid-cols-[minmax(0,1fr)_360px]">
      <!-- MAIN ARTICLE -->
      <article class="min-w-0">
        <!-- CONTENTS BAR -->
        <details class="mb-10 rounded-2xl border border-[#ff5f7e]/30 bg-[#ff5f7e]/5">
          <summary class="cursor-pointer px-5 py-4 font-mono text-xs uppercase tracking-[0.25em] text-[#ff5f7e]">
            Contents
          </summary>

          <div class="border-t border-[#ff5f7e]/20 px-5 py-5 text-sm leading-7 text-[#a9a196]">
            Use headings inside the Markdown body to create a readable writeup:
            Description, Overview, Solution, Steps, Password, Flag, Notes.
          </div>
        </details>

        <!-- METADATA QUICK BLOCK -->
        <div class="mb-10 grid gap-4 md:grid-cols-3">
          <div class="rounded-2xl border border-white/10 bg-[#111111]/80 p-5">
            <p class="font-mono text-[0.65rem] uppercase tracking-widest text-[#6f6a63]">
              Platform
            </p>
            <p class="mt-2 text-sm font-bold text-[#f3efe4]">
              {platform}
            </p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-[#111111]/80 p-5">
            <p class="font-mono text-[0.65rem] uppercase tracking-widest text-[#6f6a63]">
              Series
            </p>
            <p class="mt-2 text-sm font-bold text-[#f3efe4]">
              {series}
            </p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-[#111111]/80 p-5">
            <p class="font-mono text-[0.65rem] uppercase tracking-widest text-[#6f6a63]">
              Level
            </p>
            <p class="mt-2 text-sm font-bold text-[#f3efe4]">
              {hasLevel ? writeup.data.level : 'N/A'}
            </p>
          </div>
        </div>

        <!-- BODY -->
        <div class="rounded-3xl border border-white/10 bg-[#0d0d0d]/90 p-8 md:p-10">
          <div class="space-y-7 text-base leading-8 text-[#a9a196]
            [&_h2]:mt-14 [&_h2]:border-b [&_h2]:border-white/10 [&_h2]:pb-3 [&_h2]:font-serif [&_h2]:text-3xl [&_h2]:font-bold [&_h2]:tracking-[-0.03em] [&_h2]:text-[#f3efe4]
            [&_h3]:mt-10 [&_h3]:font-serif [&_h3]:text-2xl [&_h3]:font-bold [&_h3]:text-[#f3efe4]
            [&_p]:leading-8
            [&_ul]:ml-6 [&_ul]:list-disc [&_ol]:ml-6 [&_ol]:list-decimal [&_li]:mt-2
            [&_a]:text-[#c9ff5f] [&_a]:underline
            [&_code]:rounded-md [&_code]:border [&_code]:border-[#ead27c]/20 [&_code]:bg-[#ead27c]/10 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:font-mono [&_code]:text-sm [&_code]:text-[#ead27c]
            [&_pre]:overflow-x-auto [&_pre]:rounded-2xl [&_pre]:border [&_pre]:border-white/10 [&_pre]:bg-[#20252b] [&_pre]:p-5 [&_pre]:text-sm [&_pre]:leading-7
            [&_pre_code]:border-0 [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:text-[#f3efe4]">
            <Content />
          </div>
        </div>

        <!-- LESSON -->
        <article class="mt-10 rounded-3xl border border-[#c9ff5f]/25 bg-[#c9ff5f]/5 p-8">
          <p class="font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
            Lesson
          </p>

          <p class="mt-5 text-base leading-8 text-[#a9a196]">
            {writeup.data.lesson}
          </p>
        </article>

        <div class="mt-12 border-t border-white/10 pt-8">
          <a
            href="/writeups"
            class="font-mono text-xs uppercase tracking-widest text-[#6f6a63] transition hover:text-[#c9ff5f]"
          >
            ← Back to Writeups
          </a>
        </div>
      </article>

      <!-- SIDEBAR -->
      <aside class="space-y-6 lg:sticky lg:top-28 lg:self-start">
        <article class="rounded-3xl border border-white/10 bg-[#111111]/80 p-6">
          <p class="font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
            Writeup Info
          </p>

          <div class="mt-6 space-y-4">
            <div>
              <p class="font-mono text-[0.65rem] uppercase tracking-widest text-[#6f6a63]">
                Difficulty
              </p>
              <p class="mt-1 text-sm font-bold text-[#f3efe4]">
                {writeup.data.difficulty}
              </p>
            </div>

            <div>
              <p class="font-mono text-[0.65rem] uppercase tracking-widest text-[#6f6a63]">
                Status
              </p>
              <p class="mt-1 text-sm font-bold text-[#f3efe4]">
                {writeup.data.status}
              </p>
            </div>

            <div>
              <p class="font-mono text-[0.65rem] uppercase tracking-widest text-[#6f6a63]">
                Source file
              </p>
              <p class="mt-1 break-all font-mono text-xs text-[#a9a196]">
                src/content/writeups/{writeup.id}
              </p>
            </div>
          </div>
        </article>

        {hasTags && (
          <article class="rounded-3xl border border-white/10 bg-[#111111]/80 p-6">
            <p class="font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
              Tags
            </p>

            <div class="mt-5 flex flex-wrap gap-2">
              {writeup.data.tags.map((tag) => (
                <span class="rounded-full border border-white/10 bg-black/30 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-widest text-[#a9a196]">
                  {tag}
                </span>
              ))}
            </div>
          </article>
        )}

        <article class="rounded-3xl border border-white/10 bg-[#111111]/80 p-6">
          <p class="font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
            Tools
          </p>

          <div class="mt-5 flex flex-wrap gap-2">
            {writeup.data.tools.map((tool) => (
              <span class="rounded-full border border-white/10 bg-black/30 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-widest text-[#a9a196]">
                {tool}
              </span>
            ))}
          </div>
        </article>

        <article class="rounded-3xl border border-white/10 bg-[#111111]/80 p-6">
          <p class="font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
            Concepts
          </p>

          <div class="mt-5 grid gap-3">
            {writeup.data.concepts.map((concept, index) => (
              <div class="flex items-center justify-between gap-4 rounded-2xl border border-white/10 bg-black/30 p-4">
                <span class="font-mono text-xs text-[#c9ff5f]">
                  0{index + 1}
                </span>

                <span class="text-right text-sm font-bold text-[#f3efe4]">
                  {concept}
                </span>
              </div>
            ))}
          </div>
        </article>

        {hasExternalLink && (
          <a
            href={writeup.data.externalLink}
            target="_blank"
            class="block rounded-3xl border border-[#c9ff5f]/20 bg-[#c9ff5f] p-6 text-black transition hover:scale-[1.01]"
          >
            <p class="font-mono text-xs font-black uppercase tracking-[0.3em]">
              External Link
            </p>

            <p class="mt-5 text-sm font-bold">
              Open related challenge / reference →
            </p>
          </a>
        )}

        <article class="rounded-3xl border border-white/10 bg-[#111111]/80 p-6">
          <p class="font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
            Attached Files
          </p>

          {hasFiles && (
            <div class="mt-5 grid gap-3">
              {files.map((file) => (
                <a
                  href={file.url}
                  target="_blank"
                  class="rounded-2xl border border-white/10 bg-black/30 p-4 transition hover:border-[#c9ff5f]/60"
                >
                  <p class="font-mono text-xs uppercase tracking-widest text-[#c9ff5f]">
                    {file.type}
                  </p>

                  <p class="mt-2 text-sm font-bold text-[#f3efe4]">
                    {file.name}
                  </p>
                </a>
              ))}
            </div>
          )}

          {!hasFiles && (
            <p class="mt-5 text-sm leading-7 text-[#6f6a63]">
              No files attached.
            </p>
          )}
        </article>

        {relatedWriteups.length > 0 && (
          <article class="rounded-3xl border border-white/10 bg-[#111111]/80 p-6">
            <p class="font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
              Related
            </p>

            <div class="mt-5 grid gap-3">
              {relatedWriteups.map((item) => (
                <a
                  href={`/writeups/${item.data.slug}`}
                  class="rounded-2xl border border-white/10 bg-black/30 p-4 transition hover:border-[#c9ff5f]/60"
                >
                  <p class="font-mono text-[0.65rem] uppercase tracking-widest text-[#6f6a63]">
                    {item.data.platform || 'General'}
                  </p>

                  <p class="mt-2 text-sm font-bold leading-6 text-[#f3efe4]">
                    {item.data.title}
                  </p>
                </a>
              ))}
            </div>
          </article>
        )}
      </aside>
    </section>
  </main>
</Layout>
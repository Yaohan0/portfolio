---
import Layout from '../../layouts/Layout.astro'
import Navbar from '../../components/Navbar.astro'
import { getCollection, render } from 'astro:content'
import { withBase } from '../../utils/paths'

export async function getStaticPaths() {
  const archiveItems = await getCollection('archive')

  return archiveItems.map((item) => ({
    params: {
      slug: item.data.slug,
    },
    props: {
      item,
    },
  }))
}

const { item } = Astro.props
const { Content } = await render(item)

const hasCover = Boolean(item.data.cover)
const hasTags = item.data.tags.length > 0
const hasFiles = item.data.files.length > 0
const hasLinks = item.data.links.length > 0
---

<Layout title={`${item.data.title} — Archive`}>
  <main class="min-h-screen bg-[#090909] text-[#f3efe4]">
    <Navbar current="Archive" />

    <section class="site-grid px-6 pt-36 pb-16">
      <div class="mx-auto max-w-5xl">
        <a
          href={withBase('archive')}
          class="font-mono text-xs uppercase tracking-widest text-[#6f6a63] transition hover:text-[#c9ff5f]"
        >
          ← Back to Archive
        </a>

        <div class="mt-10 flex flex-wrap gap-2">
          <span class="rounded-full border border-[#c9ff5f]/30 bg-[#c9ff5f]/10 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-widest text-[#c9ff5f]">
            {item.data.type}
          </span>

          <span class="rounded-full border border-white/10 bg-black/30 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-widest text-[#a9a196]">
            {item.data.status}
          </span>

          <span class="rounded-full border border-white/10 bg-black/30 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-widest text-[#a9a196]">
            {item.data.date}
          </span>
        </div>

        <h1 class="display-text neon-cream mt-8 max-w-5xl text-6xl uppercase leading-none tracking-[-0.06em] md:text-8xl">
          {item.data.title}
        </h1>

        <p class="mt-8 max-w-3xl text-base leading-8 text-[#a9a196]">
          {item.data.summary}
        </p>

        {hasCover && (
          <img
            src={withBase(item.data.cover)}
            alt={item.data.title}
            class="mt-10 max-h-[560px] w-full rounded-3xl border border-white/10 object-cover"
          />
        )}
      </div>
    </section>

    <section class="mx-auto grid max-w-7xl gap-10 px-6 pb-28 lg:grid-cols-[minmax(0,1fr)_340px]">
      <article class="min-w-0">
        <div class="rounded-3xl border border-white/10 bg-[#0d0d0d]/90 p-8 md:p-10">
          <div class="space-y-7 text-base leading-8 text-[#a9a196]
            [&_h2]:mt-14 [&_h2]:border-b [&_h2]:border-white/10 [&_h2]:pb-3 [&_h2]:font-serif [&_h2]:text-3xl [&_h2]:font-bold [&_h2]:tracking-[-0.03em] [&_h2]:text-[#f3efe4]
            [&_h3]:mt-10 [&_h3]:font-serif [&_h3]:text-2xl [&_h3]:font-bold [&_h3]:text-[#f3efe4]
            [&_p]:leading-8
            [&_ul]:ml-6 [&_ul]:list-disc [&_ol]:ml-6 [&_ol]:list-decimal [&_li]:mt-2
            [&_a]:text-[#c9ff5f] [&_a]:underline
            [&_img]:rounded-2xl [&_img]:border [&_img]:border-white/10
            [&_code]:rounded-md [&_code]:border [&_code]:border-[#ead27c]/20 [&_code]:bg-[#ead27c]/10 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:font-mono [&_code]:text-sm [&_code]:text-[#ead27c]
            [&_pre]:overflow-x-auto [&_pre]:rounded-2xl [&_pre]:border [&_pre]:border-white/10 [&_pre]:bg-[#20252b] [&_pre]:p-5 [&_pre]:text-sm [&_pre]:leading-7
            [&_pre_code]:border-0 [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:text-[#f3efe4]">
            <Content />
          </div>
        </div>

        <div class="mt-12 border-t border-white/10 pt-8">
          <a
            href={withBase('archive')}
            class="font-mono text-xs uppercase tracking-widest text-[#6f6a63] transition hover:text-[#c9ff5f]"
          >
            ← Back to Archive
          </a>
        </div>
      </article>

      <aside class="space-y-6 lg:sticky lg:top-28 lg:self-start">
        <article class="rounded-3xl border border-white/10 bg-[#111111]/80 p-6">
          <p class="font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
            Archive Info
          </p>

          <div class="mt-6 space-y-4">
            <div>
              <p class="font-mono text-[0.65rem] uppercase tracking-widest text-[#6f6a63]">
                Type
              </p>
              <p class="mt-1 text-sm font-bold text-[#f3efe4]">
                {item.data.type}
              </p>
            </div>

            <div>
              <p class="font-mono text-[0.65rem] uppercase tracking-widest text-[#6f6a63]">
                Status
              </p>
              <p class="mt-1 text-sm font-bold text-[#f3efe4]">
                {item.data.status}
              </p>
            </div>

            <div>
              <p class="font-mono text-[0.65rem] uppercase tracking-widest text-[#6f6a63]">
                Date
              </p>
              <p class="mt-1 text-sm font-bold text-[#f3efe4]">
                {item.data.date}
              </p>
            </div>
          </div>
        </article>

        {hasTags && (
          <article class="rounded-3xl border border-white/10 bg-[#111111]/80 p-6">
            <p class="font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
              Tags
            </p>

            <div class="mt-5 flex flex-wrap gap-2">
              {item.data.tags.map((tag) => (
                <span class="rounded-full border border-white/10 bg-black/30 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-widest text-[#a9a196]">
                  {tag}
                </span>
              ))}
            </div>
          </article>
        )}

        <article class="rounded-3xl border border-white/10 bg-[#111111]/80 p-6">
          <p class="font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
            Links
          </p>

          {hasLinks ? (
            <div class="mt-5 grid gap-3">
              {item.data.links.map((link) => (
                <a
                  href={withBase(link.url)}
                  target="_blank"
                  class="rounded-2xl border border-white/10 bg-black/30 p-4 transition hover:border-[#c9ff5f]/60"
                >
                  <p class="text-sm font-bold text-[#f3efe4]">
                    {link.name}
                  </p>

                  <p class="mt-2 break-all font-mono text-xs text-[#6f6a63]">
                    {link.url}
                  </p>
                </a>
              ))}
            </div>
          ) : (
            <p class="mt-5 text-sm leading-7 text-[#6f6a63]">
              No links attached.
            </p>
          )}
        </article>

        <article class="rounded-3xl border border-white/10 bg-[#111111]/80 p-6">
          <p class="font-mono text-xs uppercase tracking-[0.3em] text-[#c9ff5f]">
            Files
          </p>

          {hasFiles ? (
            <div class="mt-5 grid gap-3">
              {item.data.files.map((file) => (
                <a
                  href={withBase(file.url)}
                  target="_blank"
                  class="rounded-2xl border border-white/10 bg-black/30 p-4 transition hover:border-[#c9ff5f]/60"
                >
                  <p class="font-mono text-xs uppercase tracking-widest text-[#c9ff5f]">
                    {file.type}
                  </p>

                  <p class="mt-2 text-sm font-bold text-[#f3efe4]">
                    {file.name}
                  </p>
                </a>
              ))}
            </div>
          ) : (
            <p class="mt-5 text-sm leading-7 text-[#6f6a63]">
              No files attached.
            </p>
          )}
        </article>
      </aside>
    </section>
  </main>
</Layout>
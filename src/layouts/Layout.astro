---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Yaohan — Field Archive',
  description = 'A personal cybersecurity archive for labs, CTF writeups, forensics notes, achievements, and learning documentation.',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <script
      is:inline
      src="https://identity.netlify.com/v1/netlify-identity-widget.js"
    ></script>
  </head>

  <body>
    <slot />

    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const hash = window.location.hash || "";

        if (!window.netlifyIdentity) {
          return;
        }

        window.netlifyIdentity.on("init", (user) => {
          const isIdentityAction =
            hash.includes("invite_token") ||
            hash.includes("confirmation_token") ||
            hash.includes("recovery_token") ||
            hash.includes("email_change_token");

          if (isIdentityAction) {
            window.netlifyIdentity.open();
          }

          if (!user) {
            window.netlifyIdentity.on("login", () => {
              window.location.href = "/admin/";
            });
          }
        });

        window.netlifyIdentity.init();
      });
    </script>
  </body>
</html>